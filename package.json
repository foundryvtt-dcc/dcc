{
  "author": "Tim L. White <tim@cyface.com>",
  "bugs": {
    "url": "https://github.com/foundryvtt-dcc/dcc/issues"
  },
  "description": "Dungeon Crawl Classics RPG Support for Foundry VTT",
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "husky": "^9.1.7",
    "sass": "^1.99.0",
    "standard": "^17.1.2",
    "stylelint": "^16.26.1",
    "stylelint-config-sass-guidelines": "^12.1.0",
    "vitest": "^3.2.4"
  },
  "directories": {
    "test": "module/tests"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">10.0.0"
  },
  "homepage": "https://github.com/foundryvtt-dcc/dcc#readme",
  "keywords": [
    "FoundryVTT",
    "DCC",
    "Dungeon Crawl Classics"
  ],
  "license": "MIT",
  "main": "module/dcc.js",
  "name": "dcc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foundryvtt-dcc/dcc.git"
  },
  "scripts": {
    "check": "npm run format && npm run scss && npm run test && npm run compare-lang",
    "format": "standard --fix && stylelint \"**/*.scss\" --fix",
    "test": "vitest run module/",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test-watch": "vitest module/",
    "setup:foundry": "node scripts/setup-foundry-dev.js",
    "scss": "sass styles/dcc.scss styles/dcc.css",
    "scss-watch": "sass --watch styles/dcc.scss styles/dcc.css",
    "todb": "node module/compilePacks.js",
    "tojson": "node module/extractPacks.js",
    "compare-lang": "node module/compare-lang-files.js lang/en.json lang/cn.json lang/de.json lang/es.json lang/fr.json lang/it.json lang/pl.json",
    "sync-core-lib": "node scripts/sync-core-lib.mjs",
    "prepare": "husky"
  },
  "standard": {
    "ignore": [
      "docs/**",
      "module/vendor/**"
    ]
  },
  "type": "module",
  "version": "0.50.0"
}
