{
  "enabledPlugins": {
    "foundryvtt-dev@cyface": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release:*)",
      "Bash(gh run:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(mkdir:*)",
      "Bash(npm run check)",
      "Bash(npm run compare-lang:*)",
      "Bash(npm run format:*)",
      "Bash(npm run scss:*)",
      "Bash(npm run sync-core-lib)",
      "Bash(npm run test)",
      "Bash(npm run test:integration)",
      "Bash(npm run test:unit)",
      "Bash(npm run todb)",
      "Bash(npm run tojson)",
      "Bash(npm test)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "WebFetch(domain:forums.forge-vtt.com)",
      "WebFetch(domain:foundryvtt.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": []
  }
}
